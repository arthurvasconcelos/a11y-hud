{
  "name": "a11y-hud-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for a11y-hud packages",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "pnpm --filter=@a11y-hud/example-vanilla dev",
    "dev:react": "pnpm --filter=@a11y-hud/example-react dev",
    "dev:vue": "pnpm --filter=@a11y-hud/example-vue dev",
    "build": "pnpm -r --filter='./packages/*' build",
    "test": "pnpm -r --filter='./packages/*' test",
    "test:e2e": "pnpm -r --filter='./packages/*' test:e2e",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome check .",
    "typecheck": "pnpm -r --filter='./packages/*' typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "simple-git-hooks",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@changesets/cli": "^2.27.10",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "lint-staged": "^17.0.5",
    "simple-git-hooks": "^2.11.1",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "commit-msg": "pnpm exec commitlint --edit $1"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css,md}": "biome check --write --no-errors-on-unmatched"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "pnpm": {}
}

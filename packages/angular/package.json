{
  "name": "@a11y-hud/angular",
  "version": "0.2.0",
  "description": "Angular adapter for a11y-hud — run axe-core accessibility audits in your Angular app with no DevTools required.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/a11y-hud-angular.d.ts",
      "default": "./dist/fesm2022/a11y-hud-angular.mjs"
    }
  },
  "module": "./dist/fesm2022/a11y-hud-angular.mjs",
  "types": "./dist/types/a11y-hud-angular.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "dev": "ng-packagr -p ng-package.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "a11y-hud": "workspace:*",
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "@angular/core": ">=20.0.0 <23.0.0"
  },
  "devDependencies": {
    "@angular/compiler": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@playwright/test": "^1.49.1",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.1.1",
    "ng-packagr": "^21.0.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5",
    "zone.js": "^0.16.1"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "homepage": "https://github.com/arthurvasconcelos/a11y-hud#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arthurvasconcelos/a11y-hud.git",
    "directory": "packages/angular"
  },
  "bugs": {
    "url": "https://github.com/arthurvasconcelos/a11y-hud/issues"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "axe",
    "axe-core",
    "wcag",
    "angular",
    "dev-tools",
    "overlay",
    "hud"
  ]
}

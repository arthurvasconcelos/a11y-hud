{
  "name": "a11y-hud",
  "version": "0.1.0",
  "description": "Framework-agnostic dev overlay that runs axe-core accessibility audits in your running app — no DevTools required.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axe-core": "^4.10.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^25.0.1",
    "tsup": "^8.3.5",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "homepage": "https://github.com/arthurvasconcelos/a11y-hud#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arthurvasconcelos/a11y-hud.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/arthurvasconcelos/a11y-hud/issues"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "axe",
    "axe-core",
    "wcag",
    "dev-tools",
    "overlay",
    "hud",
    "web-components",
    "custom-elements"
  ]
}
